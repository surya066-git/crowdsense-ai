rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin SDK (Cloud Run Backend) bypasses these rules entirely.
    // These rules apply ONLY to direct client-side (Frontend) queries.

    // 1. Recommendations History
    // Fans can only read recommendation history if they are authenticated,
    // or we can allow public read if the app is open access.
    // We deny client-side writes; only the Node.js backend writes recommendations.
    match /recommendations_history/{docId} {
      allow read: if true; // Publicly readable for the demo
      allow write: if false; // Only backend can write
    }

    // 2. Stadium Metadata & Live State
    match /stadium_state/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
