# PRODUCTION DEPLOYMENT
# Place this in Google Cloud Secret Manager or Cloud Run Environment Variables

PORT=8080
NODE_ENV=production

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=crowdsense-ai-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@crowdsense-ai-prod.iam.gserviceaccount.com
# Use Secret Manager for the Private Key in production to avoid exposing it
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Gemini AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Rate Limiting & Security
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=https://crowdsense-ai-prod.web.app
