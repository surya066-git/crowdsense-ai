# ==============================================================================
# CROWDSENSE AI - PRODUCTION BACKEND ENVIRONMENT VARIABLES
# ==============================================================================
# In production (Render Free Web Service), set these variables using the Render Dashboard.
# For sensitive secrets, use the Render Environment Variables tab.
# Do NOT check actual values into source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Server Configuration
# ------------------------------------------------------------------------------
# The port the Express application will listen on. Render automatically sets 
# this to 10000 (usually) and redirects incoming traffic to it.
PORT=10000

# Environment state. Set to 'production' for optimal performance, restricted errors, 
# and security checks. Allowed: development, test, production.
NODE_ENV=production

# The version prefix of the API endpoints (e.g. /api/v1). Used for API routing.
API_VERSION=v1

# The user-friendly name of the backend service, used in responses and logging.
APP_NAME=CrowdSense AI Backend

# ------------------------------------------------------------------------------
# 2. CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------
# The allowed frontend origin URL. Comma-separated list for multiple domains.
# Prevents unauthorized browser-based clients from fetching resources.
# Production Example: https://crowdsense-ai-prod.web.app,https://crowdsense-ai-prod.firebaseapp.com
FRONTEND_ORIGIN=https://crowdsense-ai-prod.web.app

# ------------------------------------------------------------------------------
# 3. Firebase SDK Configurations (Production)
# ------------------------------------------------------------------------------
# The Firebase / GCP Project ID. Required for initializing the Firebase Admin SDK.
FIREBASE_PROJECT_ID=crowdsense-ai-prod

# The Google Cloud Storage default bucket name (e.g. crowdsense-ai-prod.appspot.com).
# Used for saving stadium upload templates and CSV processing.
FIREBASE_STORAGE_BUCKET=crowdsense-ai-prod.firebasestorage.app

# Path to the Google Service Account JSON file. 
# NOTE: In Render production, you must generate a Firebase Service Account JSON, 
# stringify it, and set it as an environment variable, OR upload it as a Secret File.
# Locally: config/firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------------------------
# 4. Google Gemini AI configuration
# ------------------------------------------------------------------------------
# API Key for Google Gemini. This key must be securely injected. 
# RECOMMENDED: Store in the Render Dashboard as an Environment Variable.
GEMINI_API_KEY=your_production_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. Security & Rate Limiting Configurations
# ------------------------------------------------------------------------------
# The window duration for rate limits in milliseconds (e.g., 900000 = 15 minutes).
RATE_LIMIT_WINDOW_MS=900000

# The maximum number of general API requests allowed from a single IP during the window.
RATE_LIMIT_MAX_REQUESTS=100

# The maximum number of file uploads allowed from a single IP during the window.
UPLOAD_RATE_LIMIT_MAX_REQUESTS=10

# Maximum request execution timeout in milliseconds (e.g., 30000 = 30 seconds).
REQUEST_TIMEOUT_MS=30000

# Maximum allowable file size for CSV uploads in Megabytes.
MAX_UPLOAD_SIZE_MB=5

# ------------------------------------------------------------------------------
# 6. Logging, Monitoring & Administration
# ------------------------------------------------------------------------------
# Logging level for Pino Logger. Allowed values: fatal, error, warn, info, debug, trace, silent.
# Use 'info' or 'warn' in production to minimize logs volume and costs.
LOG_LEVEL=info

# Flag to enable simulation or demo modes when live stadium telemetry is missing.
# Options: true, false. In strict production, set to false.
ENABLE_DEMO_MODE=false

# Comma-separated list of administrator email addresses that bypass basic validation rules.
ADMIN_EMAILS=admin@crowdsense.ai,devops@crowdsense.ai
