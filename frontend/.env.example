# ==============================================================================
# CROWDSENSE AI - PRODUCTION FRONTEND ENVIRONMENT VARIABLES
# ==============================================================================
# In Vite applications, variables prefixed with 'VITE_' are static replacements 
# loaded at build time. During production deployment, ensure these are loaded in 
# the environment before running 'npm run build'.
# ==============================================================================

# 1. API Integration Service
# The base URL of the production Express backend. 
# Make sure to point this to the deployed Google Cloud Run URL.
# Note: Ensure the API version path matches the backend config (usually '/api/v1').
VITE_API_BASE_URL=https://crowdsense-backend-xxx.a.run.app/api/v1

# 2. Firebase Client SDK Web Configuration
# Retrieve these values from the Firebase Console (Project Settings > General > Web App).
# These keys are safe to expose publicly, but essential for client authentication and database sync.

# Firebase Web API Key, used by the Firebase JS Client SDK.
VITE_FIREBASE_API_KEY=AIzaSyYourProductionAPIKeyHere

# Auth Domain for redirect authorizations (e.g. Google Sign-In redirect URLs).
VITE_FIREBASE_AUTH_DOMAIN=crowdsense-ai-prod.firebaseapp.com

# Firebase Project ID. Must match the hosting project name.
VITE_FIREBASE_PROJECT_ID=crowdsense-ai-prod

# Storage bucket URL. Used by client components for direct asset access.
VITE_FIREBASE_STORAGE_BUCKET=crowdsense-ai-prod.firebasestorage.app

# Firebase Messaging Sender ID for push notifications (if used).
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Unique Web Application Identifier.
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
