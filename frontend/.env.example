# PRODUCTION ENVIRONMENT VARIABLES
# Note: Variables prefixed with VITE_ are injected into the client bundle at build time.

VITE_API_BASE_URL=https://crowdsense-api-prod-xyz.a.run.app/api/v1

# Firebase Client SDK Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=crowdsense-ai-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=crowdsense-ai-prod
VITE_FIREBASE_STORAGE_BUCKET=crowdsense-ai-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
